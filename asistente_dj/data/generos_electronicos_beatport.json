{
  "metadata": {
    "version": "1.0",
    "fecha": "2026-06-18",
    "taxonomia_raiz": "Beatport (catalogo electronico ~36 generos, estado 2025-2026)",
    "proposito": "Parametros discriminativos para reconocimiento automatico de generos/subgeneros de musica electronica",
    "notas": "Los BPM son rangos de consenso de multiples fuentes especializadas (Beatport charts, Ableton, DJ.Studio, chosic/Spotify, guias de produccion). Los valores de energia/brillo/sub_bass son escalas cualitativas orientativas (1=muy bajo, 5=muy alto) pensadas como heuristica de feature engineering, NO como medias medidas sobre un dataset. Calibrar con tu propia coleccion."
  },

  "jerarquia_decision": [
    {"paso": 1, "feature": "tempo_bpm", "descripcion": "Filtro grueso. Define el 'carril'. Recordar half-time/double-time: un tema a 140 puede percibirse a 70 (dubstep/trap) o a 140 (techno).", "tecnica": "estimacion multi-algoritmo de tempo + deteccion de half-time"},
    {"paso": 2, "feature": "base_ritmica", "descripcion": "El patron de bateria define el genero mas que la armonia. Distingue four-on-the-floor vs breakbeat vs half-time vs shuffle/2-step. Es el discriminador mas fuerte dentro de un mismo BPM.", "tecnica": "onset detection, beat tracking, posicion relativa de kick/snare en el compas, autocorrelacion ritmica"},
    {"paso": 3, "feature": "perfil_grave_y_sub_bass", "descripcion": "Energia en banda <120 Hz y diseno del bajo (sub continuo vs wobble vs reese vs rolling). Separa dubstep/DnB/bass de techno/house.", "tecnica": "energia por bandas (6 bandas octava), RMS de banda grave"},
    {"paso": 4, "feature": "brillo_espectral", "descripcion": "Centroide y rolloff espectral. Mide 'brillo'/timbre. Hard techno y trance suelen tener centroide alto; deep/organic house, bajo.", "tecnica": "spectral_centroid, spectral_rolloff, spectral_bandwidth, MFCC (timbre)"},
    {"paso": 5, "feature": "armonia_y_tonalidad", "descripcion": "Menos discriminante que el ritmo, pero util: tendencia menor/mayor, densidad de acordes, presencia de pads vs stabs. Debil para separar subgeneros vecinos.", "tecnica": "chroma/chroma_stft, tonnetz, deteccion de tonalidad (Camelot)"},
    {"paso": 6, "feature": "rasgos_alto_nivel", "descripcion": "danceability, energy, valence/mood, instrumentalness, acousticness (~0 en casi toda la electronica). Para desempatar familias.", "tecnica": "features de alto nivel estilo Spotify/Essentia"}
  ],

  "features_audio_recomendados": {
    "ritmicos": ["tempo_bpm", "deteccion_half_time", "beat_strength_por_banda", "danceability_DFA", "swing_ratio"],
    "espectrales": ["spectral_centroid", "spectral_rolloff", "spectral_bandwidth", "spectral_flux", "spectral_entropy", "zero_crossing_rate"],
    "timbricos": ["MFCC_1_13", "delta_MFCC", "spectral_contrast"],
    "armonicos": ["chroma_stft", "tonnetz", "key_scale_camelot", "key_strength"],
    "energia": ["rms_total", "rms_banda_grave_<120Hz", "rms_banda_aguda_>6kHz"],
    "libreria_sugerida": "librosa (Python) o Essentia (C++/Python) para extraccion; el set chroma+MFCC+centroide+rolloff+tempo+ZCR es el estandar de la literatura de clasificacion (GTZAN)."
  },

  "advertencia_clasificador": "Estudios recientes sugieren que la taxonomia comercial de EDM esta 'sobre-especificada': ~35 subgeneros prescritos convergen acusticamente a ~23 clusters naturales. Pares como Tech House/Minimal-Deep Tech, Techno Peak Time/Hard Techno, o Deep House/Organic House se solapan mucho. Para esos casos conviene clasificacion jerarquica (primero familia, luego subgenero) y aceptar etiquetas blandas/probabilisticas.",

