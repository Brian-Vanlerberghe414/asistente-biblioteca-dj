# Copiar a .env (no versionado) para correr local.
# EXPO_PUBLIC_* se inlinean en el bundle de JS (visible en el cliente) — por
# eso acá solo van la URL/anon key de Supabase (pensadas para ser públicas,
# la seguridad real la hace RLS) y la URL del backend, nunca una service key.
EXPO_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=tu-clave-publishable-o-anon
EXPO_PUBLIC_API_URL=https://asistente-biblioteca-dj.onrender.com
